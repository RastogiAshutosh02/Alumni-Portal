# ═══════════════════════════════════════════════
# IIT (ISM) DHANBAD ALUMNI PORTAL — ENVIRONMENT
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ism_alumni_portal
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Email (for verification — using nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=alumni@iitism.ac.in

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Allowed alumni email domains (comma separated)
ALLOWED_EMAIL_DOMAINS=iitism.ac.in,ismu.ac.in
